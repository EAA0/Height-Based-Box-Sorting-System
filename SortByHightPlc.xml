    <pous>
      <pou name="main" pouType="program">
        <interface>
          <localVars>
            <variable name="conveyor" address="%QX0.0">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[the entry conveyor that transport the boxes to the chain transfer]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="Load" address="%QX0.1">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[the conveyor on the chain transfer that move the boxes to the right place to be then transported]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="TransferLeft" address="%QX0.3">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[moves the boxes on the chain transfer to the left]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="TransferRight" address="%QX0.4">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[moves the boxes on the chain transfer to the right]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="ConveyoerLeft" address="%QX0.5">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[moves the short boxes to the remover where they get disposed]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="conveyorRight" address="%QX0.6">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[moves the tall boxes to the remover where they get disposed]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="HighSensor" address="%IX0.0">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[detects if the boxes are tall]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="LowSensor" address="%IX0.1">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[detects if the boxes are tall ( the high sensor also need to be false for this to be useful  )]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="PalletSensor" address="%IX0.2">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[detects the pallet to know to when to start the transportation]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="Loaded" address="%IX0.3">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[sensor to detect the box is in the right place to be transported]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="LeftEntry" address="%IX0.4">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[A sensor to to detect that the box has left the chain transfer and reached the left conveyor]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="at_right_entry" address="%IX0.6">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[A sensor to to detect that the box has left the chain transfer and reached the right conveyor]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="highsensor_memorybit">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[a boolean variable to save the state of the tall boxes]]></xhtml:p>
              </documentation>
            </variable>
            <variable name="lowsensor_memorybit">
              <type>
                <BOOL/>
              </type>
              <documentation>
                <xhtml:p><![CDATA[a boolean variable to save the state of the short boxes]]></xhtml:p>
              </documentation>
            </variable>
